# Скопируй этот файл в .env и заполни значения

# ── База данных ──────────────────────────────────
# Для разработки — SQLite (ничего устанавливать не нужно):
DATABASE_URL=sqlite:///kitsune.db

# Для продакшна — PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/kitsune

# ── Безопасность ─────────────────────────────────
# Обязательно смени на случайную строку в продакшне!
SECRET_KEY=замени-на-случайную-строку
JWT_SECRET_KEY=замени-на-другую-случайную-строку

# ── CORS — откуда разрешены запросы к API ────────
# Для разработки:
CORS_ORIGINS=*
# Для продакшна (укажи свой домен):
# CORS_ORIGINS=https://kitsune-play.ru

# ── Режим ────────────────────────────────────────
DEBUG=true
